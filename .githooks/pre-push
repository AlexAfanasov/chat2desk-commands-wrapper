#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

echo "[pre-push] Running local CI gate (check-handoff)..."

case "$(uname -s)" in
  MINGW*|MSYS*|CYGWIN*)
    if command -v pwsh >/dev/null 2>&1; then
      pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/check-handoff.ps1
    else
      powershell.exe -NoProfile -ExecutionPolicy Bypass -File ./scripts/check-handoff.ps1
    fi
    ;;
  *)
    ./scripts/check-handoff.sh
    ;;
esac
